# UCC Business Debt Lead Generation Platform
# Copy to .env and fill in values

# ── Database (required) ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ucc_pipeline

# ── Sentry (optional locally; use real DSN in production — numeric project id in path)
# Leave unset to run without Sentry. Placeholders like "project-id" are rejected by the SDK.
# SENTRY_DSN=https://public@o123456.ingest.sentry.io/1234567

# ── GoHighLevel Integration (optional) ───────────────────
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=
GHL_WORKFLOW_TIER1=
GHL_WORKFLOW_TIER2=
GHL_WORKFLOW_TIER3=

# ── Enrichment APIs (optional) ───────────────────────────
APOLLO_API_KEY=
PDL_API_KEY=
OPENCORPORATES_API_KEY=
WHITEPAGES_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Compliance APIs (optional) ───────────────────────────
DATAMERCH_API_KEY=
DNC_SCRUB_API_KEY=
BLACKLIST_API_KEY=

# ── Self-Healing Agent (optional) ────────────────────────
ANTHROPIC_API_KEY=

# ── GitHub Integration (optional) ────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=

# ── Alerts (optional) ────────────────────────────────────
SENDGRID_API_KEY=
MANAGER_EMAIL=

# ── Scrapers (optional) ─────────────────────────────────
# Days of filing-date history for CA JSON search window (default 3). Wider = more backfill;
# rows still dedupe in DB by state + filing_number.
# SCRAPER_FILING_LOOKBACK_DAYS=30

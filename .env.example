# UCC Business Debt Lead Generation Platform
# Copy to .env and fill in values

# ── Database (required) ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ucc_pipeline

# ── Sentry (optional locally; use real DSN in production — numeric project id in path)
# Leave unset to run without Sentry. Placeholders like "project-id" are rejected by the SDK.
# SENTRY_DSN=https://public@o123456.ingest.sentry.io/1234567

# ── GoHighLevel Integration (optional) ───────────────────
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=
GHL_WORKFLOW_TIER1=
GHL_WORKFLOW_TIER2=
GHL_WORKFLOW_TIER3=

# ── Enrichment APIs (optional) ───────────────────────────
APOLLO_API_KEY=
PDL_API_KEY=
OPENCORPORATES_API_KEY=
WHITEPAGES_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Compliance APIs (optional) ───────────────────────────
DATAMERCH_API_KEY=
DNC_SCRUB_API_KEY=
BLACKLIST_API_KEY=

# ── Self-Healing Agent (optional) ────────────────────────
ANTHROPIC_API_KEY=

# ── GitHub Integration (optional) ────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=

# ── Alerts (optional) ────────────────────────────────────
SENDGRID_API_KEY=
MANAGER_EMAIL=

# ── Scrapers (optional) ─────────────────────────────────
# Days of filing-date history for CA JSON search window (default 3). Wider = more backfill;
# rows still dedupe in DB by state + filing_number.
# SCRAPER_FILING_LOOKBACK_DAYS=30

# ── Florida scraper (manual trigger only; no scheduler job) ──
# Deep Standard pagination via rowNumber across index profiles (NOT A–Z text cursors).
# Sensible defaults for a ~5–15 min dev deep run (see README):
FL_SCRAPE_MAX_PAGES=500
FL_SCRAPE_PAGE_CAP_PER_RUN=50
FL_SCRAPE_INDEX_PROFILES=OrganizationDebtorName|FiledCompactDebtorNameList,OrganizationDebtorName|FiledActualDebtorNameList,IndividualDebtorName|FiledCompactDebtorNameList
FL_SCRAPE_ENRICH_CONCURRENCY=5
FL_SCRAPE_FETCH_FILING_DATE=true
# Exact-mode MCA lender sweep (comma-separated; dedupes with Standard pass):
FL_SCRAPE_EXACT_TERMS=OnDeck Capital,Yellowstone Capital,Pearl Capital,World Business Lenders,Credibly,Fundbox,National Funding,Everest Business Funding,Can Capital,BlueVine,Greenbox Capital,Kalamata Capital,Fox Capital Group,Rapid Capital Funding
# MCA detector
MCA_FUZZY_SCORE_CUTOFF=90
MCA_FUZZY_REQUIRE_TOKEN_OVERLAP=true
MCA_BLOCKED_LENDER_CLASSES=government,registered_agent,insurance,bank
# FL_SCRAPE_SEARCH_TERMS=  # deprecated; Standard mode ignores text

# Playwright Tier 1 (NY, NJ, CA, TX)
PLAYWRIGHT_SCRAPE_MAX_PAGES=50
PLAYWRIGHT_SCRAPE_MAX_TERMS=20
PLAYWRIGHT_SCRAPE_MCA_TERM_LIMIT=20
PLAYWRIGHT_SCRAPE_FETCH_DETAIL=true
# NY public portal has no secured-party search — debtor-name profiles only.
NY_SCRAPE_SEARCH_PROFILES=debtor_org_sw
NY_SCRAPE_MCA_TERM_LIMIT=200
# NY_SCRAPE_VARIANT_LIMIT=8   # optional cap per funder after expansion
NY_SCRAPE_MAX_PAGES=50
NY_SCRAPE_MAX_TERMS=20
NY_SCRAPE_FETCH_DETAIL=true
# NY_SCRAPE_PREFIX_TERMS=A,B,C,...,Z,0,1,...,9,LLC,INC,CORP
# NY_SCRAPE_PAGE_CAP_PER_RUN=500
# NY_SCRAPE_PAGE_ORDER=forward   # forward | reverse | recent_only
# NY_SCRAPE_RECENT_PAGES=10      # last K pages when page_order=recent_only
# NJ_SCRAPE_SEARCH_PROFILES=
# NJ secured-party lives only on per-filing detail pages — keep detail fetch on so
# NJ filings can be MCA-classified (slower: one navigation per result row).
NJ_SCRAPE_FETCH_DETAIL=true
